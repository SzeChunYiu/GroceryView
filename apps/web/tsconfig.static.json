{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "dist/assets",
    "rootDir": "src",
    "noEmit": false,
    "declaration": false,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/main.ts"]
}
