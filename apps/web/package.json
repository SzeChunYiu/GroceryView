{
  "name": "@groceryview/web",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "NODE_OPTIONS=--max-old-space-size=6144 next build --webpack",
    "dev": "next dev",
    "perf:bundle:profile": "NODE_OPTIONS=--max-old-space-size=6144 next build --profile --webpack && size-limit --config ./size-limit.config.cjs",
    "perf:lighthouse:ci": "lhci autorun --config=./lighthouserc.cjs",
    "perf:lighthouse:preview": "lhci autorun --config=./lighthouserc.preview.cjs",
    "start": "next start",
    "test": "node --test scripts/*.test.mjs",
    "e2e": "playwright test --config playwright.config.ts"
  },
  "dependencies": {
    "@groceryview/analytics": "0.1.0",
    "@groceryview/api": "0.1.0",
    "@groceryview/catalog": "0.1.0",
    "@groceryview/core": "0.1.0",
    "@groceryview/db": "0.1.0",
    "@groceryview/ops": "0.1.0",
    "@groceryview/scanning": "0.1.0",
    "@tanstack/react-query": "^5.90.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lightweight-charts": "^5.2.0",
    "lucide-react": "^0.561.0",
    "maplibre-gl": "^4.7.1",
    "next": "^16.2.6",
    "next-intl": "^4.12.0",
    "pg": "^8.21.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwind-merge": "^3.4.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@size-limit/file": "^12.1.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/geojson": "^7946.0.16",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.23",
    "axe-core": "^4.11.4",
    "postcss": "^8.5.6",
    "size-limit": "^12.1.0",
    "tailwindcss": "^3.4.19",
    "@playwright/test": "^1.51.1"
  }
}
