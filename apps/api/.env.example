NODE_ENV=development
PORT=3001
DATABASE_ENABLED=false
DATABASE_URL=postgresql://groceryview:groceryview@localhost:5432/groceryview
REDIS_URL=redis://localhost:6379
CORS_ORIGINS=http://localhost:3000

