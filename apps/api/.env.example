# API
NODE_ENV=development
PORT=3000

# Database is optional for local health/build checks. Set DATABASE_ENABLED=true
# or provide DATABASE_URL/DB_HOST to initialize the TypeORM PostgreSQL connection.
DATABASE_ENABLED=false
DATABASE_URL=postgres://postgres:postgres@localhost:5432/groceryview
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=groceryview
# DB_SSL=false
# DB_RETRY_ATTEMPTS=1
# DB_RETRY_DELAY_MS=1000
