generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        String     @id
  slug      String     @unique
  name      String
  parentId  String?    @map("parent_id")
  parent    Category?  @relation("CategoryChildren", fields: [parentId], references: [id], onDelete: Restrict)
  children  Category[] @relation("CategoryChildren")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@index([parentId])
  @@map("categories")
}

model Product {
  id             String   @id @default(uuid()) @db.Uuid
  slug           String   @unique
  canonicalName  String   @map("canonical_name")
  nameSv         String?  @map("name_sv")
  nameEn         String?  @map("name_en")
  brand          String?
  categoryPath   String[] @default([]) @map("category_path")
  comparableUnit String   @map("comparable_unit")
  imageUrl       String?  @map("image_url")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  priceChanges   PriceChange[]

  @@map("products")
}

model PriceChange {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  storeId   String   @map("store_id")
  oldPrice  Decimal  @map("old_price") @db.Decimal(10, 2)
  newPrice  Decimal  @map("new_price") @db.Decimal(10, 2)
  changedAt DateTime @default(now()) @map("changed_at")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, storeId, changedAt])
  @@map("price_changes")
}
