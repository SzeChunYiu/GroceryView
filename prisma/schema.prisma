generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        String     @id
  slug      String     @unique
  name      String
  parentId  String?    @map("parent_id")
  parent    Category?  @relation("CategoryChildren", fields: [parentId], references: [id], onDelete: Restrict)
  children  Category[] @relation("CategoryChildren")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@index([parentId])
  @@map("categories")
}

model Product {
  id             String   @id @default(uuid()) @db.Uuid
  slug           String   @unique
  canonicalName  String   @map("canonical_name")
  nameSv         String?  @map("name_sv")
  nameEn         String?  @map("name_en")
  brand          String?
  categoryPath   String[] @default([]) @map("category_path")
  comparableUnit String   @map("comparable_unit")
  imageUrl       String?  @map("image_url")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("products")
}

model UserPreferences {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @unique @map("user_id")
  preferredStoreIds String[] @default([]) @map("preferred_store_ids")
  currency          String   @default("SEK")
  locale            String   @default("sv-SE")
  displayDensity    String   @default("comfortable") @map("display_density")
  darkMode          Boolean  @default(false) @map("dark_mode")
  hiddenProductIds  String[] @default([]) @map("hidden_product_ids")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("user_preferences")
}
