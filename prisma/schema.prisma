generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        String     @id
  slug      String     @unique
  name      String
  parentId  String?    @map("parent_id")
  parent    Category?  @relation("CategoryChildren", fields: [parentId], references: [id], onDelete: Restrict)
  children  Category[] @relation("CategoryChildren")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@index([parentId])
  @@map("categories")
}

model Product {
  id             String   @id @default(uuid()) @db.Uuid
  slug           String   @unique
  canonicalName  String   @map("canonical_name")
  nameSv         String?  @map("name_sv")
  nameEn         String?  @map("name_en")
  brand          String?
  categoryPath   String[] @default([]) @map("category_path")
  comparableUnit String   @map("comparable_unit")
  imageUrl       String?  @map("image_url")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("products")
}

model BenchmarkObservation {
  id          String   @id @default(uuid()) @db.Uuid
  sourceId    String   @map("source_id")
  country     String
  vertical    String
  ecoicopCode String   @map("ecoicop_code")
  period      String
  value       Decimal  @db.Decimal(18, 6)
  unit        String
  observedAt  DateTime @map("observed_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([sourceId, country, vertical, period])
  @@map("benchmark_observation")
}
