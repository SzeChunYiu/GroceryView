generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        String     @id
  slug      String     @unique
  name      String
  parentId  String?    @map("parent_id")
  parent    Category?  @relation("CategoryChildren", fields: [parentId], references: [id], onDelete: Restrict)
  children  Category[] @relation("CategoryChildren")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@index([parentId])
  @@map("categories")
}

model Product {
  id             String   @id @default(uuid()) @db.Uuid
  slug           String   @unique
  canonicalName  String   @map("canonical_name")
  nameSv         String?  @map("name_sv")
  nameEn         String?  @map("name_en")
  brand          String?
  categoryPath   String[] @default([]) @map("category_path")
  comparableUnit String   @map("comparable_unit")
  imageUrl       String?  @map("image_url")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("products")
}

model RestockWatch {
  id                 String    @id @default(uuid()) @db.Uuid
  userId             String    @map("user_id")
  productId          String    @map("product_id")
  storeId            String?   @map("store_id")
  recipientEmail     String    @map("recipient_email")
  lastSeenOutOfStock DateTime? @map("last_seen_out_of_stock")
  lastNotifiedAt     DateTime? @map("last_notified_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@index([productId, storeId])
  @@index([userId])
  @@map("restock_watches")
}
