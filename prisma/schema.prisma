generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Store latitude/longitude radius lookups use an earthdistance GiST expression
// index defined in SQL migrations because Prisma does not model functional GiST indexes.
model Category {
  id        String     @id
  slug      String     @unique
  name      String
  parentId  String?    @map("parent_id")
  parent    Category?  @relation("CategoryChildren", fields: [parentId], references: [id], onDelete: Restrict)
  children  Category[] @relation("CategoryChildren")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@index([parentId])
  @@map("categories")
}

model Product {
  id             String   @id @default(uuid()) @db.Uuid
  slug           String   @unique
  canonicalName  String   @map("canonical_name")
  nameSv         String?  @map("name_sv")
  nameEn         String?  @map("name_en")
  brand          String?
  categoryPath   String[] @default([]) @map("category_path")
  comparableUnit String   @map("comparable_unit")
  imageUrl       String?  @map("image_url")
  isVegan        Boolean  @default(false) @map("is_vegan")
  isGlutenFree   Boolean  @default(false) @map("is_gluten_free")
  isLactoseFree  Boolean  @default(false) @map("is_lactose_free")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([isVegan])
  @@index([isGlutenFree])
  @@index([isLactoseFree])
  @@map("products")
}

model UserStoreLoyaltyCard {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id")
  storeId   String   @map("store_id")
  cardName  String   @map("card_name")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, storeId])
  @@index([storeId])
  @@map("user_store_loyalty_cards")
}

model ApiKey {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id")
  label      String
  keyPrefix  String    @map("key_prefix")
  keyHash    String    @unique @map("key_hash")
  lastUsedAt DateTime? @map("last_used_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@index([revokedAt])
  @@map("api_keys")
}
