generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Store latitude/longitude radius lookups use an earthdistance GiST expression
// index defined in SQL migrations because Prisma does not model functional GiST indexes.
model Category {
  id        String     @id
  slug      String     @unique
  name      String
  parentId  String?    @map("parent_id")
  parent    Category?  @relation("CategoryChildren", fields: [parentId], references: [id], onDelete: Restrict)
  children  Category[] @relation("CategoryChildren")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@index([parentId])
  @@map("categories")
}

model Product {
  id             String   @id @default(uuid()) @db.Uuid
  slug           String   @unique
  canonicalName  String   @map("canonical_name")
  nameSv         String?  @map("name_sv")
  nameEn         String?  @map("name_en")
  brand          String?
  categoryPath   String[] @default([]) @map("category_path")
  comparableUnit String   @map("comparable_unit")
  imageUrl       String?  @map("image_url")
  isVegan        Boolean  @default(false) @map("is_vegan")
  isGlutenFree   Boolean  @default(false) @map("is_gluten_free")
  isLactoseFree  Boolean  @default(false) @map("is_lactose_free")
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([deletedAt])
  @@index([isVegan])
  @@index([isGlutenFree])
  @@index([isLactoseFree])
  @@map("products")
}

model UserStoreLoyaltyCard {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id")
  storeId   String   @map("store_id")
  cardName  String   @map("card_name")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, storeId])
  @@index([storeId])
  @@map("user_store_loyalty_cards")
}

model Store {
  id            String   @id
  chainId       String   @map("chain_id")
  name          String
  address       String
  city          String
  district      String?
  domain        String   @default("grocery")
  latitude      Decimal? @db.Decimal(9, 6)
  longitude     Decimal? @db.Decimal(9, 6)
  storeType     String?  @map("store_type")
  openingHours  Json?    @map("opening_hours")
  onlineStoreId String?  @map("online_store_id")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([latitude, longitude])
  @@map("stores")
}

model PantryItem {
  id              String    @id
  userId          String    @map("user_id")
  productId       String    @map("product_id")
  name            String
  category        String
  quantity        Decimal   @db.Decimal(12, 3)
  unit            String
  minimumQuantity Decimal   @map("minimum_quantity") @db.Decimal(12, 3)
  targetQuantity  Decimal?  @map("target_quantity") @db.Decimal(12, 3)
  expiresOn       DateTime? @map("expires_on") @db.Date
  updatedAt       DateTime  @map("updated_at") @db.Timestamptz(6)

  @@unique([userId, productId])
  @@index([userId, productId])
  @@index([expiresOn])
  @@map("pantry_items")
}

model WatchlistRestockAlert {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id")
  productId        String    @map("product_id")
  lastOutOfStockAt DateTime? @map("last_out_of_stock_at") @db.Timestamptz(6)
  lastAvailableAt  DateTime? @map("last_available_at") @db.Timestamptz(6)
  notifiedAt       DateTime? @map("notified_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([userId, productId])
  @@index([productId, notifiedAt])
  @@map("watchlist_restock_alerts")
}

model BenchmarkObservation {
  sourceId    String   @map("source_id")
  country     String
  vertical    String
  ecoicopCode String   @map("ecoicop_code")
  period      String
  value       Decimal  @db.Decimal(18, 6)
  unit        String
  observedAt  DateTime @map("observed_at") @db.Timestamptz(6)

  @@id([sourceId, country, vertical, ecoicopCode, period])
  @@index([sourceId, period])
  @@map("benchmark_observation")
}
