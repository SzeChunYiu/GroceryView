generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BrandAlias {
  id             Int      @id @default(autoincrement())
  canonicalBrand String   @map("canonical_brand")
  alias          String
  normalizedAlias String  @map("normalized_alias")
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([normalizedAlias], map: "brand_aliases_normalized_alias_key")
  @@map("brand_aliases")
}

model FeatureFlag {
  featureKey      String   @id @map("feature_key")
  enabled         Boolean  @default(false)
  rolloutPercent  Int      @default(0) @map("rollout_percent")
  description     String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @map("updated_at")

  @@map("feature_flags")
}
