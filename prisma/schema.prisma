generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        String     @id
  slug      String     @unique
  name      String
  parentId  String?    @map("parent_id")
  parent    Category?  @relation("CategoryChildren", fields: [parentId], references: [id], onDelete: Restrict)
  children  Category[] @relation("CategoryChildren")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@index([parentId])
  @@map("categories")
}

model Product {
  id             String   @id @default(uuid()) @db.Uuid
  slug           String   @unique
  canonicalName  String   @map("canonical_name")
  nameSv         String?  @map("name_sv")
  nameEn         String?  @map("name_en")
  brand          String?
  categoryPath   String[] @default([]) @map("category_path")
  comparableUnit String   @map("comparable_unit")
  imageUrl       String?  @map("image_url")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("products")
}

model PriceChange {
  id            String   @id @default(uuid()) @db.Uuid
  productSlug   String   @map("product_slug")
  storeId       String?  @map("store_id")
  previousPrice Decimal  @map("previous_price") @db.Decimal(10, 2)
  currentPrice  Decimal  @map("current_price") @db.Decimal(10, 2)
  delta         Decimal  @db.Decimal(10, 2)
  direction     String
  source        String?
  detectedAt    DateTime @default(now()) @map("detected_at")

  @@index([productSlug, detectedAt])
  @@map("price_change")
}
