generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        String     @id
  slug      String     @unique
  name      String
  parentId  String?    @map("parent_id")
  parent    Category?  @relation("CategoryChildren", fields: [parentId], references: [id], onDelete: Restrict)
  children  Category[] @relation("CategoryChildren")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@index([parentId])
  @@map("categories")
}

model Product {
  id             String   @id @default(uuid()) @db.Uuid
  slug           String   @unique
  canonicalName  String   @map("canonical_name")
  nameSv         String?  @map("name_sv")
  nameEn         String?  @map("name_en")
  brand          String?
  categoryPath   String[] @default([]) @map("category_path")
  comparableUnit String   @map("comparable_unit")
  imageUrl       String?  @map("image_url")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  listItems      ListItem[]

  @@map("products")
}

model ShoppingList {
  id        String     @id @default(uuid()) @db.Uuid
  userId    String     @map("user_id")
  name      String
  createdAt DateTime   @default(now()) @map("created_at")
  items     ListItem[]

  @@index([userId])
  @@map("shopping_lists")
}

model ListItem {
  id        String       @id @default(uuid()) @db.Uuid
  listId    String       @map("list_id") @db.Uuid
  productId String       @map("product_id") @db.Uuid
  quantity  Int          @default(1)
  checked   Boolean      @default(false)
  note      String?
  list      ShoppingList @relation(fields: [listId], references: [id], onDelete: Cascade)
  product   Product      @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([listId])
  @@index([productId])
  @@map("list_items")
}
