generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        String     @id
  slug      String     @unique
  name      String
  parentId  String?    @map("parent_id")
  parent    Category?  @relation("CategoryChildren", fields: [parentId], references: [id], onDelete: Restrict)
  children  Category[] @relation("CategoryChildren")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@index([parentId])
  @@map("categories")
}

model Chain {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug        String   @unique
  name        String
  countryCode String   @default("SE") @map("country_code") @db.Char(2)
  websiteUrl  String?  @map("website_url")
  domain      String   @default("grocery")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  stores         Store[]
  observations   Observation[]
  priceSnapshots PriceSnapshot[]

  @@map("chains")
}

model Store {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chainId        String   @map("chain_id") @db.Uuid
  slug           String   @unique
  externalRef    String?  @map("external_ref")
  name           String
  addressLine1   String   @map("address_line1")
  addressLine2   String?  @map("address_line2")
  postalCode     String?  @map("postal_code")
  city           String
  region         String?
  countryCode    String   @default("SE") @map("country_code") @db.Char(2)
  position       Unsupported("geography(point, 4326)")?
  storeType      String   @default("supermarket") @map("store_type")
  openingHours   Json     @default("{}") @map("opening_hours")
  onlineOrderUrl String?  @map("online_order_url")
  domain         String   @default("grocery")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  chain          Chain           @relation(fields: [chainId], references: [id], onDelete: Restrict)
  observations   Observation[]
  priceSnapshots PriceSnapshot[]
  alerts         Alert[]

  @@unique([chainId, externalRef])
  @@map("stores")
}

model Product {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug              String   @unique
  canonicalName     String   @map("canonical_name")
  brand             String?
  brandOwner        String?  @map("brand_owner")
  privateLabelOwner String?  @map("private_label_owner")
  barcode           String?
  categoryPath      String[] @default([]) @map("category_path")
  packageSize       Decimal? @map("package_size") @db.Decimal(12, 3)
  packageUnit       String?  @map("package_unit")
  comparableUnit    String   @map("comparable_unit")
  nutrition         Json     @default("{}")
  imageUrl          String?  @map("image_url")
  domain            String   @default("grocery")
  fuelGradeId       String?  @map("fuel_grade_id")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  observations   Observation[]
  priceSnapshots PriceSnapshot[]
  alerts         Alert[]
  watchlists     Watchlist[]

  @@map("products")
}

model Observation {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId          String   @map("product_id") @db.Uuid
  chainId            String   @map("chain_id") @db.Uuid
  storeId            String?  @map("store_id") @db.Uuid
  sourceRunId        String?  @map("source_run_id") @db.Uuid
  rawRecordId        String?  @map("raw_record_id") @db.Uuid
  retailerProductRef String?  @map("retailer_product_ref")
  priceType          String   @map("price_type")
  price              Decimal  @db.Decimal(12, 2)
  regularPrice       Decimal? @map("regular_price") @db.Decimal(12, 2)
  unitPrice          Decimal  @map("unit_price") @db.Decimal(12, 4)
  currency           String   @default("SEK") @db.Char(3)
  quantity           Decimal? @db.Decimal(12, 3)
  quantityUnit       String?  @map("quantity_unit")
  promotionText      String?  @map("promotion_text")
  promotionStartsOn  DateTime? @map("promotion_starts_on") @db.Date
  promotionEndsOn    DateTime? @map("promotion_ends_on") @db.Date
  memberRequired     Boolean  @default(false) @map("member_required")
  observedAt         DateTime @map("observed_at") @db.Timestamptz(6)
  validFrom          DateTime? @map("valid_from") @db.Timestamptz(6)
  validUntil         DateTime? @map("valid_until") @db.Timestamptz(6)
  confidence         Decimal  @db.Decimal(5, 4)
  provenance         Json     @default("{}")
  domain             String   @default("grocery")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  product       Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  chain         Chain           @relation(fields: [chainId], references: [id], onDelete: Restrict)
  store         Store?          @relation(fields: [storeId], references: [id], onDelete: Restrict)
  priceSnapshot PriceSnapshot?

  @@map("observations")
}

model PriceSnapshot {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId     String   @map("product_id") @db.Uuid
  chainId       String   @map("chain_id") @db.Uuid
  storeId       String?  @map("store_id") @db.Uuid
  priceType     String   @map("price_type")
  observationId String   @unique @map("observation_id") @db.Uuid
  price         Decimal  @db.Decimal(12, 2)
  regularPrice  Decimal? @map("regular_price") @db.Decimal(12, 2)
  unitPrice     Decimal  @map("unit_price") @db.Decimal(12, 4)
  currency      String   @default("SEK") @db.Char(3)
  observedAt    DateTime @map("observed_at") @db.Timestamptz(6)
  confidence    Decimal  @db.Decimal(5, 4)
  provenance    Json     @default("{}")
  domain        String   @default("grocery")
  updatedAt     DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  chain       Chain       @relation(fields: [chainId], references: [id], onDelete: Cascade)
  store       Store?      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  observation Observation @relation(fields: [observationId], references: [id], onDelete: Restrict)

  @@unique([productId, chainId, storeId, priceType])
  @@map("latest_prices")
}

model User {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email               String?  @unique
  displayName         String?  @map("display_name")
  homeStoreId         String?  @map("home_store_id") @db.Uuid
  preferredCurrency   String   @default("SEK") @map("preferred_currency") @db.Char(3)
  dietaryPreferences  Json     @default("{}") @map("dietary_preferences")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  watchlists Watchlist[]
  alerts     Alert[]

  @@map("users")
}

model Watchlist {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId              String   @map("user_id") @db.Uuid
  name                String   @default("Watchlist")
  productId           String?  @map("product_id") @db.Uuid
  categoryPath        String[] @map("category_path")
  targetPrice         Decimal? @map("target_price") @db.Decimal(12, 2)
  favoriteStoresOnly  Boolean  @default(true) @map("favorite_stores_only")
  includeMemberPrices Boolean  @default(false) @map("include_member_prices")
  allowedPriceTypes   String[] @default(["shelf"]) @map("allowed_price_types")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  alerts  Alert[]

  @@map("watchlists")
}

model Alert {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String    @map("user_id") @db.Uuid
  watchlistId        String?   @map("watchlist_id") @db.Uuid
  productId          String?   @map("product_id") @db.Uuid
  storeId            String?   @map("store_id") @db.Uuid
  alertType          String    @map("alert_type")
  targetPrice        Decimal?  @map("target_price") @db.Decimal(12, 2)
  dealScoreThreshold Int?      @map("deal_score_threshold")
  active             Boolean   @default(true)
  lastTriggeredAt    DateTime? @map("last_triggered_at") @db.Timestamptz(6)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  watchlist Watchlist? @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  product   Product?   @relation(fields: [productId], references: [id], onDelete: Cascade)
  store     Store?     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@map("alerts")
}
