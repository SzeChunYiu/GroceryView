{
  "ci": {
    "collect": {
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop",
        "onlyCategories": ["performance", "accessibility", "best-practices", "seo"]
      },
      "url": [
        "__LHCI_PREVIEW_URL__/",
        "__LHCI_PREVIEW_URL__/search",
        "__LHCI_PREVIEW_URL__/list",
        "__LHCI_PREVIEW_URL__/stores",
        "__LHCI_PREVIEW_URL__/deals",
        "__LHCI_PREVIEW_URL__/categories",
        "__LHCI_PREVIEW_URL__/products",
        "__LHCI_PREVIEW_URL__/data-sources",
        "__LHCI_PREVIEW_URL__/seasonal-calendar",
        "__LHCI_PREVIEW_URL__/scan"
      ]
    },
    "assert": {
      "preset": "lighthouse:recommended",
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.78 }],
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:best-practices": ["error", { "minScore": 0.9 }],
        "categories:seo": ["error", { "minScore": 0.85 }],
        "first-contentful-paint": ["error", { "maxNumericValue": 2200 }],
        "largest-contentful-paint": ["error", { "maxNumericValue": 3500 }],
        "total-blocking-time": ["error", { "maxNumericValue": 350 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }],
        "interactive": ["error", { "maxNumericValue": 5200 }],
        "resource-summary:script:size": ["error", { "maxNumericValue": 650000 }],
        "resource-summary:total:size": ["error", { "maxNumericValue": 1800000 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
