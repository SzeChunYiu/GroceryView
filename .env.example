METRICS_TOKEN=dev-metrics-change-me
CATALOG_COVERAGE_TARGETS_JSON={"targetProducts":["coffee"],"targetCategories":["coffee"],"targetChains":["ica","willys","coop","hemkop","lidl","city_gross"],"targetStores":["willys-odenplan"],"requireEveryProductInEveryStore":true}
