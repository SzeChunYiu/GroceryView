# Required in every production deployment.
# Development values below are safe placeholders; replace them in hosted
# environments before starting API/web services because startup validation
# fails fast when the production-required keys are blank.
NODE_ENV=development
PORT=3000
PUBLIC_WEB_URL=http://localhost:5173
GROCERYVIEW_SERVER_URL=http://localhost:3000

DATABASE_URL=postgresql://groceryview:groceryview@localhost:5432/groceryview
REDIS_URL=redis://localhost:6379

AUTH_SECRET=dev-change-me
LIST_SHARE_SECRET=local-list-share-development-secret
NEXT_PUBLIC_LIST_SHARE_SECRET=local-list-share-development-secret

# API runtime configuration.
API_SERVICE_NAME=groceryview-api
REQUEST_LOGGING_ENABLED=true
GROCERYVIEW_PRODUCTION_URL=https://groceryview.se
API_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173
SCRAPER_SCHEDULER_ENABLED=true
SCRAPER_CRON_ICA=15 2 * * *
SCRAPER_CRON_WILLYS=30 2 * * *
SCRAPER_CRON_COOP=45 2 * * *
SCRAPER_CRON_HEMKOP=0 3 * * *
SCRAPER_CRON_SPECIALS=0 4 * * 1
OTEL_EXPORTER_OTLP_ENDPOINT=

# Notification, billing, and scanner integrations.
NOTIFICATION_WEBHOOK_SECRET=dev-webhook-change-me
SENDGRID_API_KEY=dev-sendgrid-change-me
SENDGRID_FROM_EMAIL=alerts@groceryview.local
EXPO_PUSH_ACCESS_TOKEN=dev-expo-push-change-me
TELEGRAM_BOT_TOKEN=dev-telegram-bot-change-me
BILLING_WEBHOOK_SECRET=dev-billing-webhook-change-me
STRIPE_SECRET_KEY=sk_test_change_me
STRIPE_PRICE_PREMIUM_MONTHLY=price_monthly_change_me
STRIPE_PRICE_PREMIUM_YEARLY=price_yearly_change_me
METRICS_TOKEN=dev-metrics-change-me
OCR_SPACE_API_KEY=dev-ocr-space-change-me
OCR_SPACE_HEALTHCHECK_IMAGE_URL=https://groceryview.example/fixtures/receipt-healthcheck.jpg
OPENFOODFACTS_USER_AGENT=GroceryView/0.1 (dev@groceryview.local)
OPENFOODFACTS_HEALTHCHECK_BARCODE=0735000123456
GROCERYVIEW_SOURCE_RUN_MIN_ACCEPTED_ROWS_BY_CHAIN={"ica":10,"willys":10,"coop":10,"hemkop":5,"lidl":5,"city_gross":5}
CATALOG_COVERAGE_TARGETS_JSON={"targetProducts":["coffee"],"targetCategories":["coffee"],"targetChains":["ica","willys","coop","hemkop","lidl","city_gross"],"targetStores":["ica-example-store","willys-example-store","coop-example-store","hemkop-example-store","lidl-example-store","city_gross-example-store"],"targetPriceTypes":["online"],"requireEveryProductInEveryStore":false,"requireEveryStorePriceType":true}
GROCERYVIEW_DAILY_CONNECTORS_JSON=[{"connectorId":"ica-store-promotions-default-stores","chainId":"ica","sourceType":"official_api","endpointUrl":"groceryview://daily/ica/store-promotions/default-stores","parserVersion":"ica-store-promotions-native-v1","robotsTxtStatus":"not_applicable","legalReviewStatus":"approved","hasDataAgreement":true,"stores":[{"storeId":"ica-example-store","name":"ica Example Store","address":"Examplegatan 1","city":"Stockholm"}]},{"connectorId":"willys-products-all-stores","chainId":"willys","sourceType":"official_api","endpointUrl":"groceryview://daily/willys/products/all-stores","parserVersion":"willys-products-native-v1","robotsTxtStatus":"not_applicable","legalReviewStatus":"approved","hasDataAgreement":true,"stores":[{"storeId":"willys-example-store","name":"willys Example Store","address":"Examplegatan 1","city":"Stockholm"}]},{"connectorId":"coop-products-all-stores","chainId":"coop","sourceType":"official_api","endpointUrl":"groceryview://daily/coop/products/all-stores","parserVersion":"coop-products-native-v1","robotsTxtStatus":"not_applicable","legalReviewStatus":"approved","hasDataAgreement":true,"stores":[{"storeId":"coop-example-store","name":"coop Example Store","address":"Examplegatan 1","city":"Stockholm"}]},{"connectorId":"hemkop-weekly-all-stores","chainId":"hemkop","sourceType":"flyer_campaign","endpointUrl":"groceryview://daily/hemkop/weekly-offers/all-stores","parserVersion":"hemkop-weekly-native-v1","robotsTxtStatus":"not_applicable","legalReviewStatus":"approved","hasDataAgreement":true,"stores":[{"storeId":"hemkop-example-store","name":"hemkop Example Store","address":"Examplegatan 1","city":"Stockholm"}]},{"connectorId":"lidl-public-offers-all-stores","chainId":"lidl","sourceType":"retailer_online_page","endpointUrl":"groceryview://daily/lidl/public-offers/all-stores","parserVersion":"lidl-public-offers-native-v1","robotsTxtStatus":"allow","legalReviewStatus":"approved","hasDataAgreement":true,"stores":[{"storeId":"lidl-example-store","name":"lidl Example Store","address":"Examplegatan 1","city":"Stockholm"}]},{"connectorId":"city-gross-public-products-all-stores","chainId":"city_gross","sourceType":"official_api","endpointUrl":"groceryview://daily/city-gross/public-products/all-stores","parserVersion":"citygross-products-native-v1","robotsTxtStatus":"not_applicable","legalReviewStatus":"approved","hasDataAgreement":true,"stores":[{"storeId":"city_gross-example-store","name":"city_gross Example Store","address":"Examplegatan 1","city":"Stockholm"}]}]
NORWAY_COVERAGE_JSON=
NORWAY_COVERAGE_AS_OF=

PGADMIN_DEFAULT_EMAIL=admin@groceryview.local
PGADMIN_DEFAULT_PASSWORD=groceryview

S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=groceryview-raw
S3_ACCESS_KEY_ID=groceryview
S3_SECRET_ACCESS_KEY=groceryview-secret
SCAN_UPLOAD_MAX_BYTES=5000000
MINIO_ROOT_USER=groceryview
MINIO_ROOT_PASSWORD=groceryview-secret
