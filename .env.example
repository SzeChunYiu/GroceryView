# Local service URLs
DATABASE_URL=postgresql://groceryview:groceryview@localhost:5432/groceryview
REDIS_URL=redis://localhost:6379

# PostgreSQL / PostGIS
POSTGRES_DB=groceryview
POSTGRES_USER=groceryview
POSTGRES_PASSWORD=groceryview
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Optional pgAdmin profile: docker compose -f infra/docker-compose.yml --profile admin up
PGADMIN_DEFAULT_EMAIL=admin@groceryview.local
PGADMIN_DEFAULT_PASSWORD=groceryview
PGADMIN_PORT=5050

# S3-compatible local object storage
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=groceryview-local
S3_ACCESS_KEY_ID=groceryview
S3_SECRET_ACCESS_KEY=groceryview-secret
SCAN_UPLOAD_MAX_BYTES=5000000
MINIO_ROOT_USER=groceryview
MINIO_ROOT_PASSWORD=groceryview-secret
