{
  "name": "groceryview",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npx turbo run build",
    "test": "npx turbo run test && npm run ingest:verify && node --test tests/schema/*.test.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "ingest:generate-live": "npm run build -w @groceryview/ingestion && node scripts/ingestion/generate-live-retailer-ingested.mjs",
    "ingest:openfoodfacts-db": "npm run build -w @groceryview/ingestion && node scripts/ingestion/persist-openfoodfacts-metadata.mjs",
    "ingest:verify": "node scripts/ingestion/verify-ingested-provenance.mjs",
    "ops:catalog-coverage-targets": "node scripts/ops/print-catalog-coverage-targets.mjs",
    "ops:apply-db-migrations": "npm run build -w @groceryview/db && node scripts/ops/apply-db-migrations.mjs",
    "ops:check-production-secrets": "node scripts/ops/check-production-secrets.mjs",
    "ops:check-daily-db-connectivity": "node scripts/ops/check-daily-db-connectivity.mjs",
    "ops:db-io-hotspots": "node scripts/ops/check-daily-db-connectivity.mjs --pg-stat-statements-io",
    "ops:compare-db-io-hotspots": "node scripts/ops/compare-db-io-hotspots.mjs",
    "ops:daily-connectors": "npm run build -w @groceryview/ingestion && node scripts/ops/print-daily-connectors.mjs",
    "ops:daily-connector-stores": "npm run build -w @groceryview/ingestion && node scripts/ops/print-daily-connector-stores.mjs",
    "ops:validate-production-env": "node scripts/ops/validate-production-env.mjs",
    "ingest:export-db-snapshot": "npm run build -w @groceryview/db && node scripts/ingestion/export-db-site-snapshot.mjs",
    "ops:check-supabase-health": "node scripts/ops/check-supabase-project-health.mjs",
    "ops:db-recovery-packet": "node scripts/ops/print-production-db-recovery-packet.mjs",
    "ops:validate-db-cutover": "node scripts/ops/validate-db-cutover.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3"
  }
}
